# Neo4j (default password is LOCAL DEV ONLY — change before any exposed host)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=aria_dev_password
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# LLM (Ollama local-first, switchable via LiteLLM)
# Used by the app and by readiness/ingest checks: GET /ready and `aria status` report `llm`;
# `aria ingest` preflight requires Neo4j + Chroma + LLM. Configure before relying on those paths.
LLM_MODEL=ollama/llama3.2
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=not-needed-for-ollama

# CLI (`aria` after `pip install -e .` — loads this file via python-dotenv)
# Typical flow: start Neo4j/Chroma (e.g. docker compose), set vars above, then `aria init`
# before `aria ingest <file>` on a new database. README → section "CLI (`aria`)".

# API
# Exposed deployments: prefer binding loopback or a private IP and terminating TLS + auth at a
# reverse proxy; use host firewall rules as defense in depth.
# Example local-only bind: API_HOST=127.0.0.1
API_HOST=0.0.0.0
API_PORT=8080
# Optional: require X-API-Key or Authorization: Bearer <key> on data routes and (by default)
# on GET /metrics and GET /telemetry. /health and /ready stay unauthenticated.
# API_KEY=
# ARIA_API_KEY=
# When API_KEY is set, allow unauthenticated /metrics and /telemetry only on trusted networks
# (path-level stats aid reconnaissance). Internal-only: ARIA_OBSERVABILITY_PUBLIC=true
# Comma-separated origins, or * for any origin (do not use credentials + * in browsers).
# CORS_ORIGINS takes precedence over CORS_ALLOW_ORIGINS when both are set.
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Placeholder vs live: when true (default), GET /impact and POST /query return synthetic data
# with X-ARIA-Mode: placeholder. When false, live mode requires Neo4j (impact), Chroma + LLM (query).
# ARIA_PLACEHOLDER_API=true

# Optional: reject Pydantic payloads whose schema_version does not match (e.g. 0.1.0)
# ARIA_STRICT_SCHEMA_VERSION=0.1.0
# DEPLOYMENT_ENV=production  # disables /docs and OpenAPI JSON
# Ingest body size (defaults align at 12 MiB when unset):
# - ARIA_MAX_INGEST_BODY_BYTES — middleware rejects POST /ingest* when Content-Length exceeds this.
# - INGEST_MAX_BYTES — application limit when reading /ingest/text and /ingest/file bodies.
# ARIA_MAX_INGEST_BODY_BYTES=12582912
# INGEST_MAX_BYTES=12582912

# A2A agents: when set, require X-A2A-Secret on /a2a/card and /a2a/tasks
# A2A_SHARED_SECRET=

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json

# Telemetry
ARIA_TELEMETRY_DB=aria_telemetry.db
# Long-running deployments: cap SQLite growth by deleting rows older than N days (UTC) and
# VACUUM when something was removed. Prune runs once at startup and then every interval.
# ARIA_TELEMETRY_RETENTION_DAYS=30
# ARIA_TELEMETRY_PRUNE_INTERVAL_SECONDS=86400
# External cron (same tables; HTTP rows live in `requests`, not `http_requests`): run a one-off
# prune with the same cutoff semantics as the app (do not mix raw sqlite3 string compares on `ts`
# with SQLite datetime() literals — formats differ). Example from repo root with ARIA_TELEMETRY_DB set:
# python -c "from aria.observability.telemetry_store import TelemetryStore; s=TelemetryStore(); s.prune_older_than(retention_days=30); s.close()"
# GET /telemetry JSON includes requests.by_path — treat like sensitive ops data unless
# ARIA_OBSERVABILITY_PUBLIC=true or the process is not reachable from untrusted networks.
